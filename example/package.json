{
  "name": "react-native-huawei-obs-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "react-native build-ios --mode Debug",
    "clean:android": "cd android && ./gradlew clean && cd .. && rm -rf android/build/generated/autolinking",
    "clean": "rm -rf android/build node_modules/.cache android/build/generated/autolinking"
  },
  "dependencies": {
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-documents/viewer": "^4.0.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-file-viewer": "^2.1.5",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^8.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@react-native-community/cli-platform-ios": "18.0.0",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/metro-config": "0.79.2",
    "@react-native/typescript-config": "0.79.2",
    "@types/react": "^19.0.0",
    "react-native-builder-bob": "^0.40.18",
    "react-native-monorepo-config": "^0.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
